{
  "name": "zterm",
  "private": true,
  "version": "0.1.0",
  "description": "Windows-first Tauri terminal workspace for SSH, SFTP, command history, and AI-assisted operations.",
  "type": "module",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test:frontend": "vitest run --passWithNoTests",
    "tauri": "tauri",
    "tauri:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-tauri-msvc.ps1 dev",
    "tauri:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-tauri-msvc.ps1 build",
    "check": "npm run typecheck && npm run test:frontend && npm run build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zmodem.js": "^0.1.10",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
